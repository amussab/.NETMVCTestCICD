@model IEnumerable<PatientManagementSystem.Models.Patient>

@{
    ViewData["Title"] = "Patients";
}

<h1>Patients</h1>

<form asp-action="Index" method="get">
    <div class="row mb-3">
        <div class="col-md-4">
            <input type="text"
                   name="searchString"
                   class="form-control"
                   placeholder="Search by Medical Number" />
        </div>

        <div class="col-md-2">
            <button type="submit"
                    class="btn btn-primary">
                Search
            </button>
        </div>
    </div>
</form>

<p>
    <a asp-action="Create" class="btn btn-success">Create New</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Medical Number</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>City</th>
            <th>State</th>
            <th>Zip Code</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.medicalNumber</td>
                <td>@item.firstName</td>
                <td>@item.lastName</td>
                <td>@item.city</td>
                <td>@item.state</td>
                <td>@item.zipCode</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.medicalNumber">Details</a> |
                    <a asp-action="Edit" asp-route-id="@item.medicalNumber">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.medicalNumber">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>